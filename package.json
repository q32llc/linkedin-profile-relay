{
  "name": "linkedin-profile-relay",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension: scrape LinkedIn profiles and POST to registered CRM endpoints",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "build:prod": "node build.mjs --prod",
    "zip": "node build.mjs --prod && cd dist-prod && zip -r ../linkedin-profile-relay.zip .",
    "watch": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:save-login": "node tests/save-login.mjs",
    "test:e2e": "node tests/e2e.spec.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "@types/chrome": "^0.0.268",
    "playwright": "^1.41.0",
    "vitest": "^1.2.0"
  },
  "packageManager": "pnpm@10.19.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@esbuild/linux-x64"
    ]
  }
}